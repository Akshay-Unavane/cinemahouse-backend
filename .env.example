PORT=5000
MONGO_URL=mongodb://127.0.0.1:27017/cinemahouse
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated frontend URLs allowed by CORS (optional)
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# NODE_ENV=production

# Show OTP in API response when email is not configured
RESET_OTP_DEV_MODE=true

# Email (Gmail example — use App Password, not your normal password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=CinemaHouse <your@gmail.com>
