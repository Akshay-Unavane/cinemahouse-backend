PORT=5000
MONGO_URL=mongodb://127.0.0.1:27017/cinemahouse
JWT_SECRET=replace-with-a-long-random-secret

# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Gmail — required for forgot-password OTP emails
# 1. Google Account → Security → enable 2-Step Verification
# 2. App passwords → create for "Mail" → copy 16-character password (no spaces)
SMTP_SERVICE=gmail
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=CinemaHouse <your@gmail.com>
